<% nodes = compute_resource.nodes %>
<% unless local_assigns[:hide_image] && !new_vm %>
    <%
      arch ||= nil ; os ||= nil
      images = possible_images(compute_resource, arch, os)
    -%>
<% end %>
<% content_for(:javascripts) do %>
  <%= webpacked_plugins_js_for :foreman_fog_proxmox %>
<%= javascript_include_tag 'foreman_fog_proxmox/proxmox_vm', "data-turbolinks-track" => true %>
<% end %>
<%= f.fields_for :volumes do |i| %>
	<% logger.warn("************ volume fields #{i.object} ........... #{i.object.hard_disk?}  #{i.object.storage_type} " ) %>
<% end %>

<% logger.warn("************ f fields #{f.object.config.cpu_type}  #{f.object.image_id} " ) %>
<%= react_component('ProxmoxVmType',  { vm_attributes: object_to_attributes_hash(f.object, from_profile), nodes: nodes, images: images, pools: compute_resource.pools, storages: compute_resource.storages(f.object.node_id), from_profile: from_profile, new_vm: new_vm}) %>
